# Copy to .env.local (never commit secrets to a public repo).

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_DATABASE_URL=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Default tournament node id under tournaments/{id}
VITE_DEFAULT_TOURNAMENT_ID=cup2026

# Optional: extra admin emails for the dashboard only (comma-separated).
# RTDB writes still require the same emails in database.rules.json OR config/adminUids/{uid}.
# VITE_ADMIN_EMAILS=

# Optional: show the Students admin block (default hidden).
# VITE_SHOW_STUDENTS=true
